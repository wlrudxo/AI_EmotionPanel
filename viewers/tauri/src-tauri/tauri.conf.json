{
  "$schema": "https://raw.githubusercontent.com/nicorevin/tauri/v2/packages/api/src/schemas/config.json",
  "productName": "Claude Emotion",
  "version": "1.0.0",
  "identifier": "com.claude-emotion.viewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Emotion",
        "width": 300,
        "height": 420,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src https://cdn.jsdelivr.net"
    }
  }
}
